# Core Django
DJANGO_SECRET_KEY=change-this-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.up.railway.app,localhost:5173
TIME_ZONE=UTC

# App URLs
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Database (Railway Postgres plugin will provide DATABASE_URL automatically)
DATABASE_URL=postgresql://postgres:postgres@db:5432/library_management

# CORS/CSRF
DJANGO_CORS_ALLOW_ALL_ORIGINS=false
DJANGO_CORS_ALLOW_CREDENTIALS=true
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# Security/cookies
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=Lax
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_PATH=/
REFRESH_COOKIE_MAX_AGE=604800
SECURE_SSL_REDIRECT=false

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@example.com

# Startup behavior
RUN_MIGRATIONS=true
COLLECT_STATIC=true
CREATE_SUPERUSER=false
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_ROLE=admin
DJANGO_SUPERUSER_FIRST_NAME=System
DJANGO_SUPERUSER_LAST_NAME=Admin

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
